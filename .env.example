# =============================================================================
# ECB intressimäärad ja sektorite aktsiatootlus — keskkonnamuutujad
#
# Kasutamine:
#   cp .env.example .env
#   # Muuda allpool märgitud väärtused enne docker compose up käivitamist
#   # SUPERSET_SECRET_KEY genereerimine:
#   #   python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
# -----------------------------------------------------------------------------
# Analüütika andmebaas (analytics-db konteiner)
# Siia lähevad kõik staging / intermediate / marts andmed
# -----------------------------------------------------------------------------
POSTGRES_USER=praktikum
POSTGRES_PASSWORD=praktikum        # MUUDA tootmiskeskkonnas
POSTGRES_DB=praktikum
DB_PORT_HOST=55432                 # Port hostis (konteineris on alati 5432)

# -----------------------------------------------------------------------------
# Airflow metaandmebaas (airflow-db konteiner — eraldi DB)
# -----------------------------------------------------------------------------
AIRFLOW_USER=airflow
AIRFLOW_PASSWORD=airflow           # MUUDA tootmiskeskkonnas
AIRFLOW_PASSWORD=airflow           # MUUDA tootmiskeskkonnas
AIRFLOW_DB=airflow
AIRFLOW_PORT_HOST=8080

# Airflow JWT autentimine (API ja scheduleri vaheline suhtlus)
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret   # MUUDA tootmiskeskkonnas
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# Airflow UI admin kasutaja
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow   # MUUDA tootmiskeskkonnas

# Airflow konteineris kasutatav UID.
# Linuxis PEAB see vastama sinu kasutaja UID-le, muidu tekivad volume-i õiguste vead.
# Käivita terminalis: echo "AIRFLOW_UID=$(id -u)" >> .env
# Macis ja Windowsis võib 50000 jääda muutmata.
AIRFLOW_UID=50000

# Lisapakid, mis installitakse Airflow konteinerisse käivitamisel
# dbt-postgres: transformatsioonid
# yfinance + pandas: indeksite hindade tõmbamine Yahoo Finance'ist
# requests: ECB API päringud
_PIP_ADDITIONAL_REQUIREMENTS=dbt-core==1.10.22 dbt-postgres==1.10.0 yfinance pandas==2.2.3 requests==2.32.3 curl_cffi==0.7.4

# -----------------------------------------------------------------------------
# Superset metaandmebaas (superset-db konteiner — eraldi DB)
# -----------------------------------------------------------------------------
SUPERSET_DB_USER=superset
SUPERSET_DB_PASSWORD=superset      # MUUDA tootmiskeskkonnas
SUPERSET_DB_NAME=superset

# Superset admin kasutaja (UI sisselogimine)
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin      # MUUDA tootmiskeskkonnas
SUPERSET_ADMIN_EMAIL=admin@example.com

# Superset salajane võti — PEAB olema unikaalne ja keeruline!
# Genereeri: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=CHANGE_ME_generate_with_python_secrets

SUPERSET_PORT_HOST=8088
