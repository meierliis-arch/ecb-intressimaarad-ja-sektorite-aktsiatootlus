    select
        date_ref,
        rate_pct,
        fetched_at,
        row_number() over (
            partition by date_ref
            order by fetched_at desc
        ) as row_num
    from source
)

select
    date_ref,
    rate_pct,
    fetched_at
from deduplicated
where row_num = 1
  );
